@model AnalyzeViewModel
@{
    ViewData["Title"] = "Error Log Analyzer";
}

<section class="hero">
    <h1>Error Log Analyzer</h1>
    <p class="subtitle">Ask a plain-English question about a production error. The agent queries your logs, deployment history, and source changes to explain the root cause.</p>
</section>

<section class="analyzer">
    <form asp-action="Analyze" method="post">
        <div class="field">
            <label>LLM Provider</label>
            <div class="provider-options">
                <label>
                    <input type="radio" asp-for="Provider" value="SelfHosted" id="provider-selfhosted" />
                    Self-hosted (Ollama)
                </label>
                <label>
                    <input type="radio" asp-for="Provider" value="Groq" id="provider-groq" />
                    Groq API
                </label>
            </div>
        </div>
        <div class="field" id="api-key-field" style="display:none">
            <label asp-for="ApiKey">Groq API Key</label>
            <input asp-for="ApiKey" type="password" placeholder="gsk_..." autocomplete="off" />
            <span asp-validation-for="ApiKey" class="validation-error"></span>
        </div>
        <div class="field">
            <label asp-for="Question">Your question</label>
            <textarea asp-for="Question"
                      rows="3"
                      placeholder="e.g. What caused the NullReferenceException after yesterday's deployment?"></textarea>
            <span asp-validation-for="Question" class="validation-error"></span>
        </div>
        <button type="submit" class="btn-analyze">Analyze</button>
    </form>

    <script>
        (function () {
            var radios = document.querySelectorAll('input[name="Provider"]');
            var keyField = document.getElementById('api-key-field');
            function toggle() {
                keyField.style.display = document.getElementById('provider-groq').checked ? '' : 'none';
            }
            radios.forEach(function (r) { r.addEventListener('change', toggle); });
            toggle();
        })();
    </script>

    @if (Model.Error is not null)
    {
        <div class="result error">
            <strong>Error:</strong> @Model.Error
        </div>
    }

    @if (Model.HasResult)
    {
        <div class="result answer">
            <h2>Root Cause Hypothesis</h2>
            <p>@Model.Answer</p>
            <p class="disclaimer">This is an AI-generated hypothesis. Verify before acting on it.</p>
        </div>
    }
</section>

<section class="example-questions">
    <h3>Example questions</h3>
    <ul>
        <li>Summarize all production errors from the last 3 days.</li>
        <li>Why is PaymentService.ChargeAsync timing out?</li>
        <li>What changed in production in the last few days that might have caused new errors?</li>
    </ul>
</section>
